# Unix
alias tlf="tail -f"
alias -g G='| grep'
alias -g M='| less'
alias -g L='| wc -l'
alias -g ONE="| awk '{ print \$1}'"
alias e='$EDITOR'
alias v='$VISUAL'
alias rcp='rsync -avz --progress'

# Pretty print the path
alias path='echo $PATH | tr -s ":" "\n"'

# Tmuxifier
alias tmd='tmuxifier load-window default'
alias tmmonitor='tmuxifier load-window monitor'
alias tmvmonitor='tmuxifier load-window vmonitor'
alias tmvd='tmuxifier load-window vdefault'

# Matlab REPL
alias matlabrepl='matlab -nodesktop -nosplash'

# iPython notebook
alias nb='ipython notebook --profile=nbserver'

# Include custom aliases
[[ -f ~/.aliases.local ]] && source ~/.aliases.local
